# Rapid7 InsightVM Cloud Integrations API
RAPID7_API_KEY=replace-me
RAPID7_REGION=ca

# Automox is only required when running with --upload
AUTOMOX_API_KEY=replace-me
AUTOMOX_ORG_ID=123456

# Optional Azure Key Vault secret source
# SECRET_SOURCE=azure-keyvault
# AZURE_KEY_VAULT_URL=https://your-vault-name.vault.azure.net/
# RAPID7_API_KEY_SECRET=rapid7-api-key
# AUTOMOX_API_KEY_SECRET=automox-api-key
# AUTOMOX_ORG_ID_SECRET=automox-org-id
